# Optional affiliate / partner IDs (production: map from GitHub Secrets in deploy workflow).
# Vite only exposes variables prefixed with VITE_.
#
# GitHub Actions (deploy.yml): secrets TCGPLAYER_IMPACT_ID, TCGPLAYER_AD_ID,
# TCGPLAYER_PARTNER_SEGMENT (Impact path segment, e.g. 21018), MANA_POOL_ID → VITE_* below.
#
# VITE_TCGPLAYER_IMPACT_ID=
# VITE_TCGPLAYER_AD_ID=
# VITE_TCGPLAYER_PARTNER_SEGMENT=
# VITE_MANA_POOL_REF=
# Optional: destination URL for Deck Editor "Mass Entry" partner link (defaults to https://www.tcgplayer.com/)
# VITE_TCGPLAYER_MASS_ENTRY_URL=
